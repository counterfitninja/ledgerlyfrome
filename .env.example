
# Copy this file to .env and fill in your values.
# The app reads these at startup via os.environ.get().

# Flask
SECRET_KEY=change-me-to-a-random-string
ADMIN_PASSWORD=your-admin-password

# Mail — Microsoft 365
# Use your full M365 email address as the username.
# If your tenant has modern auth / security defaults enabled, you may need to
# create an app password or enable SMTP AUTH for the mailbox in the M365 admin
# centre: https://admin.microsoft.com → Users → Active users → select user →
# Mail tab → Manage email apps → tick "Authenticated SMTP"
MAIL_SERVER=smtp.office365.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=you@yourdomain.com
MAIL_PASSWORD=your-m365-password
