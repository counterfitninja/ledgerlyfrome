
# Copy this file to .env and fill in your values.
# The app reads these at startup via os.environ.get().

# Flask
SECRET_KEY=change-me-to-a-random-string
ADMIN_PASSWORD=your-admin-password

# Mail — SMTP provider
# Microsoft 365 example:
#   MAIL_SERVER=smtp.office365.com
#   MAIL_PORT=587
#   MAIL_USE_TLS=true
#   MAIL_USERNAME=you@yourdomain.com
#   MAIL_PASSWORD=your-m365-password-or-app-password
# Gmail example:
#   MAIL_SERVER=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_USE_TLS=true
#   MAIL_USERNAME=youraddress@gmail.com
#   MAIL_PASSWORD=your-google-app-password
# Note: Gmail typically requires a Google App Password when 2-Step Verification
# is enabled. Regular account passwords may not work for SMTP.
MAIL_SERVER=smtp.office365.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=you@yourdomain.com
MAIL_PASSWORD=your-smtp-password
