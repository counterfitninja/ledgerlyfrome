
# Copy this file to .env and fill in your values.
# The app reads these at startup via os.environ.get().

# Flask
SECRET_KEY=change-me-to-a-random-string
ADMIN_PASSWORD=your-admin-password

# Mail — SMTP provider
# Select provider: smtp (default) or m365_graph
MAIL_PROVIDER=smtp

# Microsoft 365 example:
#   MAIL_SERVER=smtp.office365.com
#   MAIL_PORT=587
#   MAIL_USE_TLS=true
#   MAIL_USERNAME=you@yourdomain.com
#   MAIL_PASSWORD=your-m365-password-or-app-password
# Gmail example:
#   MAIL_SERVER=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_USE_TLS=true
#   MAIL_USERNAME=youraddress@gmail.com
#   MAIL_PASSWORD=your-google-app-password
# Note: Gmail typically requires a Google App Password when 2-Step Verification
# is enabled. Regular account passwords may not work for SMTP.
MAIL_SERVER=smtp.office365.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=you@yourdomain.com
MAIL_PASSWORD=your-smtp-password

# Microsoft 365 Graph app-auth (recommended when SMTP AUTH is disabled):
# MAIL_PROVIDER=m365_graph
# Setup checklist (Azure/Entra):
# 1) Entra ID > App registrations > New registration
# 2) Copy Directory (tenant) ID -> M365_TENANT_ID
# 3) Copy Application (client) ID -> M365_CLIENT_ID
# 4) Certificates & secrets > New client secret -> M365_CLIENT_SECRET
# 5) API permissions > Microsoft Graph > Application permissions > Mail.Send
# 6) Grant admin consent for tenant
# 7) Set sender mailbox -> M365_SENDER (must exist and be allowed by policy)
# M365_TENANT_ID=00000000-0000-0000-0000-000000000000
# M365_CLIENT_ID=11111111-1111-1111-1111-111111111111
# M365_CLIENT_SECRET=your-app-client-secret
# M365_SENDER=you@yourdomain.com
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=
M365_SENDER=
